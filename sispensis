<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SISPENSIS</title>

<script src="https://cdn.tailwindcss.com"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.23/jspdf.plugin.autotable.min.js"></script>

<style>
body{
  font-family: 'Segoe UI', sans-serif;
  background: linear-gradient(135deg,#4f46e5,#22c55e);
}
.card{
  background:skyblue;
  border-radius:16px;
  padding:20px;
  box-shadow:0 10px 25px rgba(0,0,0,0.1);
}
.header{
  background: linear-gradient(90deg,#4f46e5,#6366f1);
  color:white;
  border-radius:16px;
  padding:20px;
}
</style>
</head>

<body class="p-4">
<div class="max-w-6xl mx-auto space-y-6">

<!-- HEADER -->
<div class="header text-center">
  <h1 class="text-3xl font-bold">SISPENSIS</h1>
  <p>Sistem Pencatatan Pelanggaran Siswa</p>
</div>

<!-- STATISTIK -->
<div class="grid grid-cols-3 gap-4">
  <div class="card text-center">
    <h3>Minggu Ini</h3>
    <p id="minggu" class="text-2xl font-bold">0</p>
  </div>
  <div class="card text-center">
    <h3>Bulan Ini</h3>
    <p id="bulan" class="text-2xl font-bold">0</p>
  </div>
  <div class="card text-center">
    <h3>Total</h3>
    <p id="total" class="text-2xl font-bold">0</p>
  </div>
</div>

<!-- INPUT -->
<div class="header text-center">
  <h1 class="text-3xl font-bold">INPUT DATA</h1>
</div>

<div class="card space-y-2">
<input id="nama" class="w-full border p-2 rounded" placeholder="Nama">

<!-- KELAS BARU -->
<div class="grid grid-cols-2 gap-2">
  <select id="kelasTingkat" class="w-full border p-2 rounded">
    <option value="">Pilih Kelas</option>
    <option value="7">Kelas 7</option>
    <option value="8">Kelas 8</option>
    <option value="9">Kelas 9</option>
  </select>

  <select id="kelasHuruf" class="w-full border p-2 rounded">
    <option value="">Rombel</option>
    <option value="A">A</option>
    <option value="B">B</option>
    <option value="C">C</option>
  </select>
</div>

<input id="pelapor" class="w-full border p-2 rounded" placeholder="Pelapor">

<textarea id="detailPelanggaran" class="w-full border p-2 rounded" placeholder="Detail Pelanggaran"></textarea>

<select id="pelanggaran" class="w-full border p-2 rounded">
<option value="">Kategori</option>
<option>Ringan</option>
<option>Sedang</option>
<option>Berat</option>
</select>

<input id="tindakan" class="w-full border p-2 rounded" placeholder="Tindakan">
<input id="tanggal" class="w-full border p-2 rounded" placeholder="Tanggal">

<div class="flex gap-2">
<button onclick="simpan()" class="bg-indigo-600 text-white p-2 w-full rounded">Simpan</button>
<button onclick="resetForm()" class="bg-gray-500 text-white p-2 w-full rounded">Reset</button>
</div>
</div>

<!-- FILTER -->
<div class="card flex gap-2">
<input id="cariNama" onkeyup="tampil()" class="border p-2 w-full" placeholder="Cari Nama">
<input id="filterKelas" onkeyup="tampil()" class="border p-2 w-full" placeholder="Filter Kelas (7/8/9)">
</div>

<!-- TABEL -->
<div class="card">
<table class="w-full text-sm border">
<thead class="bg-indigo-100">
<tr>
<th>Tanggal</th><th>Nama</th><th>Kelas</th>
<th>Pelanggaran</th><th>Detail</th>
<th>Tindakan</th><th>Pelapor</th><th>Aksi</th>
</tr>
</thead>
<tbody id="tabel"></tbody>
</table>
</div>

<!-- PDF -->
<div class="card">
<button onclick="downloadPDF()" class="bg-red-600 text-white p-2 w-full rounded">Download PDF</button>
</div>

</div>

<script>
let data = JSON.parse(localStorage.getItem("dataPelanggaran")) || [];
let editIndex = -1;
const { jsPDF } = window.jspdf;

function simpan(){
let kelasGabung =
document.getElementById("kelasTingkat").value +
document.getElementById("kelasHuruf").value;

let d = {
nama: document.getElementById("nama").value.trim(),
kelas: kelasGabung,
pelapor: document.getElementById("pelapor").value.trim(),
pelanggaran: document.getElementById("pelanggaran").value,
detail: document.getElementById("detailPelanggaran").value.trim(),
tindakan: document.getElementById("tindakan").value.trim(),
tanggal: document.getElementById("tanggal").value.trim()
};

if(!d.nama || !kelasGabung || !d.tanggal){
alert("Isi data penting!");
return;
}

if(editIndex>=0){
data[editIndex]=d;
editIndex=-1;
}else{
data.push(d);
}

localStorage.setItem("dataPelanggaran",JSON.stringify(data));
tampil();
resetForm();
}

function tampil(){
let tabel=document.getElementById("tabel");
tabel.innerHTML="";

let cari=document.getElementById("cariNama").value.toLowerCase();
let filter=document.getElementById("filterKelas").value;

data.forEach((d,i)=>{
if(!d.nama.toLowerCase().includes(cari)) return;
if(filter && !d.kelas.startsWith(filter)) return;

let warna="black";
if(d.pelanggaran=="Ringan") warna="orange";
if(d.pelanggaran=="Sedang") warna="purple";
if(d.pelanggaran=="Berat") warna="red";

tabel.innerHTML+=`
<tr class="text-center border">
<td>${d.tanggal}</td>
<td>${d.nama}</td>
<td>${d.kelas}</td>
<td style="color:${warna};font-weight:bold">${d.pelanggaran}</td>
<td>${d.detail}</td>
<td>${d.tindakan}</td>
<td>${d.pelapor}</td>
<td>
<button onclick="editData(${i})">✏️</button>
<button onclick="hapusData(${i})">🗑️</button>
<button onclick="surat(${i})">📄</button>
</td>
</tr>
`;
});

minggu.innerText=data.length;
bulan.innerText=data.length;
total.innerText=data.length;
}

function editData(i){
let d=data[i];

document.getElementById("nama").value=d.nama;
document.getElementById("kelasTingkat").value=d.kelas.charAt(0);
document.getElementById("kelasHuruf").value=d.kelas.charAt(1);
document.getElementById("pelapor").value=d.pelapor;
document.getElementById("pelanggaran").value=d.pelanggaran;
document.getElementById("detailPelanggaran").value=d.detail;
document.getElementById("tindakan").value=d.tindakan;
document.getElementById("tanggal").value=d.tanggal;

editIndex=i;
}

function hapusData(i){
if(confirm("Hapus?")){
data.splice(i,1);
localStorage.setItem("dataPelanggaran",JSON.stringify(data));
tampil();
}
}

function resetForm(){
document.getElementById("nama").value="";
document.getElementById("kelasTingkat").value="";
document.getElementById("kelasHuruf").value="";
document.getElementById("pelapor").value="";
document.getElementById("pelanggaran").value="";
document.getElementById("detailPelanggaran").value="";
document.getElementById("tindakan").value="";
document.getElementById("tanggal").value="";
editIndex=-1;
}

function downloadPDF(){
if(data.length===0){
alert("Data kosong!");
return;
}

let doc=new jsPDF();

let kelas7=data.filter(d=>d.kelas.startsWith("7"));
let kelas8=data.filter(d=>d.kelas.startsWith("8"));
let kelas9=data.filter(d=>d.kelas.startsWith("9"));

function buat(judul, arr){
if(arr.length===0) return;

doc.text(judul,14,15);

let rows=arr.map(d=>[
d.tanggal,d.nama,d.kelas,d.pelanggaran,d.detail,d.tindakan,d.pelapor
]);

doc.autoTable({
startY:20,
head:[["Tanggal","Nama","Kelas","Pelanggaran","Detail","Tindakan","Pelapor"]],
body:rows
});

doc.addPage();
}

buat("Kelas 7",kelas7);
buat("Kelas 8",kelas8);
buat("Kelas 9",kelas9);

doc.save("laporan.pdf");
}

function surat(i){
let d=data[i];
let doc=new jsPDF();

doc.text("SURAT PEMANGGILAN",20,20);
doc.text("Nama: "+d.nama,20,40);
doc.text("Kelas: "+d.kelas,20,50);
doc.text("Pelanggaran: "+d.pelanggaran,20,60);
doc.text("Detail: "+d.detail,20,70);
doc.text("Tindakan: "+d.tindakan,20,80);

doc.save("surat_"+d.nama+".pdf");
}

tampil();
</script>

</body>
</html>
